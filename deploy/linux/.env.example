# ─── Banco de Dados ────────────────────────────────────────────────────────────
# Padrão: SQLite (sem servidor, arquivo local)
DATABASE_URL=sqlite:////opt/mcmv-rural/data/mcmv_rural.db

# Para migrar para PostgreSQL no futuro, troque por:
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/mcmv_rural

# Para Databricks SQL (se necessário):
# DATABASE_URL=databricks+connector://token:SEU_PAT@SEU_HOST.azuredatabricks.net/default?http_path=/sql/1.0/warehouses/ID

# ─── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
